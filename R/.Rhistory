library(tidyverse)
library(readxl)
library(foreign)
library(sf)
library(ggrepel)
library(mapsPERU)
library(stringi)
library(stringr)
Mapa_Departamento <- st_as_sf(Mapa_Departamento)
Departamentos_Mineros <- unique(Transferencias_Regionales$name)
Mapa_Departamento <- Mapa_Departamento %>%
mutate(DEPARTAMENTO_UPPER = toupper(DEPARTAMENTO))
Mapa_Departamento <- Mapa_Departamento %>%
mutate(
DEPARTAMENTO_UPPER = stri_trans_general(DEPARTAMENTO_UPPER, "Latin-ASCII"),
Mineria = ifelse(DEPARTAMENTO_UPPER %in% Departamentos_Mineros, "Mining Region", "Non-mining Region")
)
ggplot(Mapa_Departamento) +
geom_sf(aes(fill = Mineria), color = "white") +
geom_sf(data = Mapa_Departamento, fill = NA, color = "black", size = 0.3) +
scale_fill_manual(values = c("Mining Region" = "goldenrod", "Non-mining Region" = "gray80")) +
geom_text_repel(data = Mapa_Departamento,
aes(x = coords_x, y = coords_y, label = DEPARTAMENTO_UPPER),
size = 2.5, fontface = "bold",
max.overlaps = 20, box.padding = 0.4, point.padding = 0.2, segment.color = "gray60") +
labs(title = "Mining vs. Non-Mining Regions in Peru", fill = "") +
theme_minimal()
setdiff(Mapa_Departamento$DEPARTAMENTO_UPPER, Departamentos_Mineros) #No existen departamentos que no reciban Canon!
Mapa_Provincia <- st_as_sf(Mapa_Provincia)
Mapa_Provincia <- Mapa_Provincia %>%
mutate(PROVINCIA_UPPER = toupper(PROVINCIA),
PROVINCIA_UPPER = case_when(
PROVINCIA_UPPER == "PROV. CONST. DEL CALLAO" ~ "CALLAO",
PROVINCIA_UPPER == "LIMA" ~ "LIMA METROPOLITANA",
TRUE ~ PROVINCIA_UPPER))
Mapa_Provincia <- Mapa_Provincia %>%
mutate(
PROVINCIA_UPPER = stri_trans_general(PROVINCIA_UPPER, "Latin-ASCII"))
#Para realizar el mapa, armonizar los nombres de provincias
setdiff(Transferencias_Provinciales$name, Mapa_Provincia$PROVINCIA_UPPER)
Transferencias_Provinciales <- Transferencias_Provinciales %>%
mutate(name = case_when(
name == "NAZCA" ~ "NASCA",
name == "CAÑETE" ~ "CANETE",
name == "SANCHEZ CERRO" ~ "GENERAL SANCHEZ CERRO",
name == "DANIEL CARRION" ~ "DANIEL ALCIDES CARRION",
name == "CUZCO" ~ "CUSCO",
name == "QUISPICANCHIS" ~ "QUISPICANCHI",
name == "MARAÑON" ~ "MARANON",
name == "FERREÑAFE" ~ "FERRENAFE",
name == "DANIEL A. CARRION" ~ "DANIEL ALCIDES CARRION",
name == "DATEM DEL MARAÑON" ~ "DATEM DEL MARANON",
TRUE ~ name
))  #Qué pasa con CASCAS, HUACHO, SAN JOSE DE SISA
Provincias_Mineras <- unique(Transferencias_Provinciales$name)
Mapa_Provincia <- Mapa_Provincia %>%
mutate(
Mineria = ifelse(PROVINCIA_UPPER %in% Provincias_Mineras, "Mining Province", "Non-mining Province")
)
ggplot(Mapa_Provincia) +
geom_sf(aes(fill = Mineria), color = "white") +
geom_sf(data = Mapa_Provincia, fill = NA, color = "black", size = 0.3) +
scale_fill_manual(values = c("Mining Province" = "goldenrod", "Non-mining Province" = "gray80")) +
labs(title = "Mining vs. Non-Mining Provinces in Peru", fill = "") +
theme_minimal()
setdiff(Mapa_Provincia$PROVINCIA_UPPER, Provincias_Mineras) #No existen provincias que no reciban Canon!
Mapa_Distrito <- st_as_sf(Mapa_Distrito)
Mapa_Distrito <- Mapa_Distrito %>%
mutate(
DISTRITO = str_replace_all(DISTRITO, "_", " "),
DISTRITO = str_replace_all(DISTRITO, "-", " ")
)
Mapa_Distrito <- Mapa_Distrito %>%
mutate(DISTRITO_UPPER = toupper(DISTRITO))
Mapa_Distrito <- Mapa_Distrito %>%
mutate(
DISTRITO_UPPER = str_remove(DISTRITO_UPPER, "\\s*\\([^\\)]+\\)"),
DISTRITO_UPPER = stri_trans_general(DISTRITO_UPPER, "Latin-ASCII"),
)
Transferencias_Municipales <- Transferencias_Municipales %>%
mutate(
name = str_remove(name, "\\s*\\([^\\)]+\\)"),
name = stri_trans_general(name, "Latin-ASCII"),
)
setdiff(Transferencias_Municipales$name, Mapa_Distrito$DISTRITO_UPPER)
